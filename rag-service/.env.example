# Copy to rag-service/.env and fill in. The Azure OpenAI credentials are the same
# ones used by exam-trainer/server/.env.

# --- Azure OpenAI (required) ---
AZURE_OPENAI_ENDPOINT=https://<your-resource>.services.ai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_CHAT_DEPLOYMENT=gpt-5.4-mini
AZURE_EMBED_DEPLOYMENT=text-embedding-3-large

# --- Server (optional) ---
# RAG_PORT=8009
# RAG_RETRIEVAL_K=6
# RAG_GRADE_THRESHOLD=0.30
# RAG_MAX_CHUNK_CHARS=1800
# RAG_CHROMA_DIR=/absolute/path/to/.chroma

# --- LangSmith tracing (optional; leave blank to disable = safe no-op) ---
# Setting a key auto-enables tracing; the per-wiki project comes from wikis.yaml.
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=rag-service
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
